{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "chobitfile",
  "compatibility_date": "2026-07-21",
  "workers_dev": true,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "chobitfile.nanabit.dev",
      "custom_domain": true
    }
  ]
}
