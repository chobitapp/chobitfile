// foreign_library: WASM を JS から呼ぶためのエクスポート設定
pkgtype(kind: "foreign_library")

import {
  "moonbitlang/core/buffer" @buffer,
}

options(
  link: {
    "wasm-gc": {
      "exports": [
        "pad_zeros",
        "pad_pattern",
        "crc32_pattern",
        "zip_store",
        "text_pad",
      ],
      "use-js-builtin-string": true,
    },
  },
)
