{
  "name": "chobitfile",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome check --write .",
    "deploy": "pnpm build && wrangler deploy",
    "build:wasm": "cd moonbit-bench && moon build --release --target=wasm-gc && cd .. && node scripts/copy-wasm.mjs",
    "bench": "pnpm build:wasm && node --expose-gc bench/run.mjs",
    "bench:quick": "pnpm build:wasm && node --expose-gc bench/run.mjs --sizes 1,10 --iters 3",
    "bench:serve": "pnpm build:wasm && python3 -m http.server 8765 --directory bench"
  },
  "devDependencies": {
    "@astryxdesign/cli": "^0.1.6",
    "@biomejs/biome": "^2.5.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  },
  "dependencies": {
    "@astryxdesign/core": "^0.1.6",
    "@astryxdesign/theme-neutral": "^0.1.6",
    "nuqs": "^2.9.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
